  "i18n": {
    "en": {
      "when_to_use": "Use it to render DOCX binary in the browser as an HTML preview that preserves pagination, headers, footers, images, and styles, instead of parsing OOXML by hand, which fails at ZIP relationships, Word style cascading, and page reconstruction. Not for document editing, writing changes back, or a pixel-perfect Word clone.",
      "why_valuable": "AI cannot parse DOCX ZIP binary directly by default, much less resolve OOXML relationships, numbering, fonts, headers, footers, and images and map them to readable HTML/CSS.",
      "data_in": {
        "note": "picks uses text-span as the primary shape term, but the real native entry point consumes .docx bytes rather than text; document must be Blob, ArrayBuffer, or Uint8Array, and renderAsync is the stable upstream API.",
        "schema": {
          "document": "Blob | ArrayBuffer | Uint8Array -- Complete .docx binary; do not pass extracted XML or plain text",
          "options?": {
