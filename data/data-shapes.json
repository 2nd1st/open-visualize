    "note": "复合形态(timeseries=sequence+temporal, choropleth=tabular/geometry+geospatial, weighted-graph=graph+weighted, schedule=interval-set+temporal)作 alias 索引,非原语;模块声明可接受的多签名"
  },
  "shapes": [
    {
      "name": "tabular",
      "axis": "structural",
      "definition": "扁平记录集,行=实体、列=字段(每列带类型/角色)。data-explore 的主形态。与 grid 的区别:行是实体不是坐标;与 sequence 的区别:多字段、无强制序。",
      "data_in_example": "{\"records\":[{\"date\":\"2024-01\",\"region\":\"East\",\"revenue\":120}],\"fields\":{\"date\":\"temporal\",\"region\":\"nominal\",\"revenue\":\"quantitative\"}}",
      "example_modules": [
        "Vega-Lite",
        "Observable Plot",
        "ECharts",
        "Chart.js",
        "Tabulator",
        "Grid.js",
        "AG Grid Community",
        "AntV S2",
        "Perspective",
        "simple-statistics"
      ],
      "composes_with": [
        "temporal",
        "quantitative",
        "categorical",
        "geospatial",
        "relational-ref"
      ]
    },
    {
      "name": "sequence",
      "axis": "structural",
      "definition": "单轴有序数组/序列(index 有序)。timeseries = sequence + temporal(复合别名,非原语);不带 temporal 就是普通信号/折线序列。",
      "data_in_example": "{\"series\":[{\"id\":\"cpu\",\"points\":[[0,12],[1,18],[2,9]]}]}",
      "example_modules": [
        "uPlot",
        "Chart.js(line)",
        "ECharts(line)",
        "sparkline 类"
      ],
      "composes_with": [
        "temporal",
        "quantitative"
      ]
    },
    {
      "name": "hierarchy",
      "axis": "structural",
      "definition": "有根树、单父节点(parent-child)。是 graph 的受约束子集(无环、单入边);data-first 匹配时优先于 graph。",
      "data_in_example": "{\"root\":{\"name\":\"src\",\"children\":[{\"name\":\"index.ts\",\"value\":320}]}}",
      "example_modules": [
        "d3-hierarchy(tree/treemap/pack)",
        "markmap",
        "mind-elixir",
        "simple-mind-map",
        "@andypf/json-viewer(树视角)"
      ],
      "composes_with": [
        "quantitative",
        "weighted"
      ]
    },
    {
      "name": "graph",
      "axis": "structural",
      "definition": "节点+边、多对多拓扑、无固有坐标(布局由引擎算)。AI 纯文本对图结构表达力≈零(三家共识),是差异化最硬的形态。与 geometry 区别:拓扑无坐标。",
      "data_in_example": "{\"nodes\":[{\"id\":\"a\",\"label\":\"A\"}],\"edges\":[{\"id\":\"e1\",\"source\":\"a\",\"target\":\"b\",\"weight\":3}]}",
      "example_modules": [
        "Cytoscape.js",
        "vis-network",
        "Sigma.js+graphology",
        "force-graph",
        "elkjs",
        "d3-graphviz",
        "JSON Crack",
        "graphql-voyager"
      ],
      "composes_with": [
        "weighted",
        "categorical",
        "relational-ref"
      ]
    },
    {
      "name": "key-value",
      "axis": "structural",
      "definition": "扁平/嵌套对象、配置 map、metadata。键即语义,无行列/序结构。config 面板与 JSON 树的主形态。",
      "data_in_example": "{\"theme\":\"dark\",\"limits\":{\"tokens\":8192,\"depth\":6},\"flags\":[\"beta\"]}",
      "example_modules": [
