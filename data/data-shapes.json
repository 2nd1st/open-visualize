    {
      "name": "temporal",
      "axis": "modifier",
      "definition": "某字段承载 日期/时间/instant 语义(ISO 8601 + 显式时区)。把 sequence→timeseries、interval-set→schedule。带 DST/时区歧义风险,须存绝对时间 + 显式 tz,事件同返 instant + formatted local。",
      "data_in_example": "{\"field\":\"ts\",\"type\":\"temporal\",\"tz\":\"UTC\",\"values\":[\"2024-01-01T09:00:00Z\"]}",
      "example_modules": [
        "uPlot",
        "vis-timeline",
        "Frappe Gantt",
        "FullCalendar",
