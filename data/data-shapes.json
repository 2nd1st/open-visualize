      "data_in_example": "{\"items\":[{\"id\":\"t1\",\"label\":\"Design\",\"start\":\"2024-01-01\",\"end\":\"2024-01-05\",\"group\":\"team-a\"}],\"groups\":[{\"id\":\"team-a\"}]}",
